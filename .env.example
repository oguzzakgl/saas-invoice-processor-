# Projenize özel ayarları bu dosyadan kopyalayarak ".env" dosyasına yapıştırın.
GEMINI_API_KEY=BURAYA_KENDI_API_KEYINIZI_GIRIN

# Dizin Yolları
INPUT_DIR=data/input
OUTPUT_DIR=data/output

# Tercih edilen Model
MODEL_NAME=gemini-2.5-flash

DATABASE_URL=sqlite+aiosqlite:///data/saas_db.sqlite

# ─────────────────────────────────────────────────────────────
# Mail Bot Ayarları (Opsiyonel — mail_bot.py için gerekli)
# Gmail kullanıyorsanız: Hesap → Güvenlik → Uygulama Şifresi
# ─────────────────────────────────────────────────────────────
MAIL_IMAP_SERVER=imap.gmail.com
MAIL_IMAP_PORT=993
MAIL_ADDRESS=MAILINIZI_GIRIN@gmail.com
MAIL_PASSWORD=UYGULAMA_SIFRENIZI_GIRIN
MAIL_CHECK_INTERVAL=60
